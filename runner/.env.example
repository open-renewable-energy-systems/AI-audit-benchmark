# 
# This is the ENV file that you should adapt with your credentials
#

# Runs configuration
RUNS_PER_MODEL=5

# Local model choice and credentials 
LOCAL_LLM_MODEL=
LOCAL_LLM_URL=
LOCAL_LLM_API_KEY=
# >> Example for Llama.cpp with Qwen3.6:
# LOCAL_LLM_MODEL="unsloth/Qwen3.6"
# LOCAL_LLM_URL="http://localhost:8080/v1"
# LOCAL_LLM_API_KEY="skip"

# OpenAI credentials and model choice
OPENAI_MODEL=
OPENAI_API_KEY=

# Anthropic credentials and model choice
ANTHROPIC_MODEL=
ANTHROPIC_API_KEY=

# Mistral credentials and model choice
MISTRAL_MODEL=
MISTRAL_API_KEY=